PROVIDER_MODE=mock
SERVICE_MODE=proxy
PERSISTENCE_BACKEND=sqlite
FORWARD_PROXY_HOST=127.0.0.1
FORWARD_PROXY_PORT=8080
SOCKS5_PROXY_HOST=127.0.0.1
SOCKS5_PROXY_PORT=1080
CONTROL_API_HOST=127.0.0.1
CONTROL_API_PORT=8081

# Control-plane authentication and the trusted principal claim attached to access grants.
# The placeholder token is accepted only for local mock mode on loopback.
# Set CONTROL_API_IDENTITIES_CONFIGURED=true in SST and store the
# ControlApiIdentities secret to authorize more than one principal.
# CONTROL_API_IDENTITIES_JSON={"replace-with-a-strong-token":"trusted-user-id"}
CONTROL_API_TOKEN=change-me
CONTROL_API_USER_ID=local-dev

ADVERTISED_PROXY_HOST=127.0.0.1
ADVERTISED_HTTP_PROXY_PROTOCOL=http
SQLITE_PATH=./data/profound.db
# Required only when PERSISTENCE_BACKEND=dynamodb; SST sets this automatically.
# ROUTE_TABLE_NAME=profound-route-state
ALLOWED_TARGET_PORTS=80,443
CONNECT_TIMEOUT_MS=10000
OPERATION_TIMEOUT_MS=30000
STREAM_IDLE_TIMEOUT_MS=60000
MAX_HEADER_BYTES=32768

# Up to two peers in each of the two currently configured providers.
RETRY_MAX_ATTEMPTS=4

# Device-backed sessions always use durable, exclusive leases with the v0
# service-wide 15-minute sliding idle timeout; it is not caller-configurable.
# Mock inventory is provider-guaranteed. Live mode remains unsupported for
# authenticated exact-city routes until a guarantee or pre-commit verifier exists.
# PROXIDIZE_EXACT_CITY_SUPPORT=unsupported

# Standard OpenTelemetry configuration. No exporter is contacted unless one
# of the exporter variables is explicitly configured.
OTEL_SERVICE_NAME=profound-proxy-router
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp

# SST selects provider-specific infrastructure behind a common deployment
# boundary. AWS is the only implemented provider in v0.
# DEPLOYMENT_PROVIDER=aws
# AWS v0 runs the data plane, control plane, health, internal dashboard,
# usage-accounting, notification, and telemetry components as separate ECS
# Fargate services. The proxy NLB is
# internal; these transport settings do not control the 15-minute device lease.
# PROXY_DOMAIN=proxy.internal.example.com
# PROXY_CERT_ARN=arn:aws:acm:...
# CONTROL_DOMAIN=proxy-control.internal.example.com
# CONTROL_CERT_ARN=arn:aws:acm:...
# SOCKS5 TCP-listener idle timeout. AWS fixes TLS listeners at 350 seconds.
# NLB_TCP_IDLE_TIMEOUT_SECONDS=1200
# NLB_DEREGISTRATION_DELAY_SECONDS=300
# Deployed collectors export to three pre-created Axiom datasets. Operational
# and canary-security logs share the log dataset but remain distinguishable by
# `log.category`; traces and metrics use their own datasets. The ingestion token
# is stored with `sst secret set AxiomIngestToken`, never in this file.
# AXIOM_OTLP_ENDPOINT=https://api.axiom.co
# AXIOM_LOGS_DATASET=profound-proxy-router-staging-logs
# AXIOM_TRACES_DATASET=profound-proxy-router-staging-traces
# AXIOM_METRICS_DATASET=profound-proxy-router-staging-metrics
# All three telemetry datasets default to 30 days. This value must match their
# Axiom retention policies.
# TELEMETRY_RETENTION_DAYS=30

# The accounting worker owns the durable ledger and rollups; OTLP is only an
# operational copy. Provider totals reconcile matching periods when available.
# SERVICE_MODE=usage-accounting
# USAGE_ACCOUNTING_HOST=127.0.0.1
# USAGE_ACCOUNTING_PORT=8085
# USAGE_ACCOUNTING_INTERVAL_MS=60000
# PROVIDER_COST_TOTALS_JSON=[]
# Unassigned device intervals are charged to the synthetic Unallocated customer.
# UNALLOCATED_DEVICE_CAPACITY_JSON=[]
# Optional publisher endpoint returning providerTotals and unallocatedDeviceCapacity.
# USAGE_ACCOUNTING_SOURCE_URL=http://internal-accounting-source/v1/totals
# USAGE_ACCOUNTING_SOURCE_TOKEN=replace-with-a-strong-token
# USAGE_ACCOUNTING_SOURCE_TOKEN_CONFIGURED=true
# USAGE_ACCOUNTING_SOURCE_TIMEOUT_MS=10000
# USAGE_VARIANCE_ABSOLUTE_FLOOR_USD=1
# USAGE_VARIANCE_WARNING_RELATIVE=0.05
# USAGE_VARIANCE_ERROR_RELATIVE=0.15

# Required only when PROVIDER_MODE=live.
BRIGHT_DATA_CUSTOMER_ID=
BRIGHT_DATA_ZONE=
BRIGHT_DATA_PASSWORD=
BRIGHT_DATA_API_KEY=
# BRIGHT_DATA_STATUS_API_URL=https://api.brightdata.com/network_status/res
BRIGHT_DATA_HOST=brd.superproxy.io
BRIGHT_DATA_PORT=33335
PROXIDIZE_API_TOKEN=
PROXIDIZE_API_BASE_URL=https://api.proxidize.com

# Independently runnable health/status services. The SST stack supplies these
# values and deploys each mode with a separate runtime identity.
# SERVICE_MODE=health-aggregator
# HEALTH_AGGREGATOR_HOST=127.0.0.1
# HEALTH_AGGREGATOR_PORT=8082
# HEALTH_AGGREGATOR_TOKEN=replace-with-a-strong-token
# HEALTH_PROVIDER_REFRESH_MS=60000
# HEALTH_PASSIVE_MAX_AGE_MS=300000
# HEALTH_SYNTHETIC_COOLDOWN_MS=300000
# Capability and recovery alert ownership is fixed to the health aggregator for
# v0. Axiom monitors may own separate non-capability engineering alerts only.
# HEALTH_ALERT_DEGRADED_DELAY_MS=300000
# HEALTH_ALERT_WEBHOOK_TIMEOUT_MS=5000
# HEALTH_ALERT_WEBHOOK_MAX_ATTEMPTS=5
# HEALTH_ALERT_WEBHOOK_INITIAL_BACKOFF_MS=1000
# The aggregator needs only non-secret routing metadata; the separate
# notification service receives the complete signed-webhook secret below.
# HEALTH_ALERT_CONFIGURATION_VERSION=2026-07-15
# HEALTH_ALERT_DESTINATION_IDS=primary-ops
# HEALTH_ALERT_DESTINATIONS_JSON={"version":"2026-07-15","destinations":[{"id":"primary-ops","url":"https://alerts.example.com/profound","secret":"replace-with-a-long-signing-secret"}]}
# HEALTH_CANARY_URL=http://127.0.0.1:8090/v1/challenge
# HEALTH_PROXY_URL=http://127.0.0.1:8080
# HEALTH_PROXY_USERNAME=ACCESS_GRANT_ID
# HEALTH_PROXY_PASSWORD=ACCESS_GRANT_TOKEN

# SERVICE_MODE=status
# STATUS_APP_HOST=127.0.0.1
# STATUS_APP_PORT=8083
# STATUS_STALE_AFTER_MS=300000
# STATUS_HISTORY_LIMIT=100
# HEALTH_AGGREGATOR_URL=http://127.0.0.1:8082

# SERVICE_MODE=notification
# NOTIFICATION_HOST=127.0.0.1
# NOTIFICATION_PORT=8084
# NOTIFICATION_POLL_INTERVAL_MS=5000

# SERVICE_MODE=canary
# CANARY_HOST=127.0.0.1
# CANARY_PORT=8090
# CANARY_SIGNING_SECRET=replace-with-a-strong-secret
# Comma-separated network CIDRs whose peers may supply X-Forwarded-For.
# Leave empty for a directly bound local canary.
# CANARY_TRUSTED_PROXY_CIDRS=127.0.0.0/8
# CANARY_REQUESTS_PER_MINUTE=60
# Local MaxMind GeoLite2 City MMDB and twice-weekly updater. Configure both
# credentials together; without a database, responses use geo.status=unavailable.
# GEOIP_DATABASE_PATH=./data/GeoLite2-City.mmdb
# GEOIP_MAX_ACCURACY_RADIUS_KM=100
# GEOIP_UPDATE_INTERVAL_MS=302400000
# MAXMIND_ACCOUNT_ID=
# MAXMIND_LICENSE_KEY=
# For AWS, run `pnpm geoip:prepare` in the deployment pipeline at least twice
# weekly. SST packages the staged MMDB and metadata with the canary Lambda.
# GEOIP_BUNDLE_DIRECTORY=.sst/geoip
# GEOIP_DATABASE_SOURCE=.sst/geoip/GeoLite2-City.mmdb

# Stage-independent caller-facing lifecycle suite. The control URL and token
# default to the local values above; a controlled recipient is required.
# E2E_CONTROL_API_URL=http://127.0.0.1:8081
# E2E_CONTROL_API_TOKEN=change-me
# Defaults to https://example.com/.
# E2E_TARGET_URL=https://example.com/
# E2E_EXPECTED_TARGET_STATUS=200

# AWS acceptance suite. Deploy an ephemeral ci-* stage (which automatically
# includes both serverless and plain-HTTP controlled recipients), start
# `pnpm sst tunnel --stage <stage>`, then provide these values to `pnpm test:aws`.
# DEPLOYED_STAGE=ci-manual
# DEPLOYED_CONTROL_API_TOKEN=replace-with-the-stage-secret
# DEPLOYED_HEALTH_AGGREGATOR_TOKEN=replace-with-the-stage-secret
# DEPLOYED_CANARY_SIGNING_SECRET=replace-with-the-stage-secret
# Query-scoped Axiom token used only by the comprehensive deployed checks.
# DEPLOYED_AXIOM_QUERY_TOKEN=replace-with-a-query-token
# DEPLOYED_AXIOM_API_URL=https://api.axiom.co
# DEPLOYED_EXPECTED_USER_ID=sst:ci-manual
# DEPLOYED_RUN_DISRUPTIVE_TESTS=1
# DEPLOYED_EXPECTED_TELEMETRY_RETENTION_DAYS=30
