{
  "name": "profound-proxy-router",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-neutral residential and mobile forward proxy router",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "msgpackr-extract",
      "protobufjs"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "test": "pnpm build && node --test dist/tests/*.test.js dist/tests/**/*.test.js",
    "test:live": "pnpm build && RUN_LIVE_PROXY_TESTS=1 node --test dist/tests/live/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "effect": "^3.21.4"
  }
}
